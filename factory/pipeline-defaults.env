# Checked-in pipeline defaults. Keep secrets and local overrides in ../.env.

# Processing
PG_TIMEOUT=180

# Collector
COLLECTOR_TIMEOUT=120

# Analyzer
MAX_DOCUMENT_LEN=6144

EMBEDDER_PATH=avsolatorio/GIST-small-Embedding-v0
EMBEDDER_CONTEXT_LEN=512

EXTRACTOR_PATH=knowledgator/modern-gliner-bi-base-v1.0
EXTRACTOR_CONTEXT_LEN=2048

VECTOR_LEN=384
CLUSTER_EPS=0.145

DIGESTOR_PATH=vllm://Qwen/Qwen3-4B-Instruct-2507
DIGESTOR_CONTEXT_LEN=8192
DIGESTOR_TEMPERATURE=0.4
DIGESTOR_TOP_P=0.8
DIGESTOR_TOP_K=25
DIGESTOR_REPETITION_PENALTY=1.1

# Consolidator
CONSOLIDATOR_PATH=vllm://nvidia/NVIDIA-Nemotron-3-Nano-4B-BF16
CONSOLIDATOR_CONTEXT_LEN=16384
CONSOLIDATOR_TEMPERATURE=0.8
CONSOLIDATOR_TOP_P=0.95
CONSOLIDATOR_REPETITION_PENALTY=1.1
CONSOLIDATION_EPS=0.41
CONSOLIDATION_MAX_SIZE=48

